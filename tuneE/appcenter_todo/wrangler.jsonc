{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "appcenter-todo", 
  "main": ".open-next/worker.js", 
  "compatibility_date": "2024-04-28",
  "compatibility_flags": [
    "nodejs_compat" 
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true 
  }
}